{
  "name": "@klickkk/db",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:generate": "prisma generate --env-file ../../.env",
    "db:push": "prisma db push --env-file ../../.env",
    "db:migrate": "prisma migrate dev --env-file ../../.env",
    "db:studio": "prisma studio --env-file ../../.env",
    "db:seed": "node --env-file=../../.env -r ts-node/register prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "prisma": "^6.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
