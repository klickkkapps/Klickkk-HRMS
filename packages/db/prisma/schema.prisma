generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  STARTER
  GROWTH
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum SupplyType {
  INTRA_STATE
  INTER_STATE
}

enum InvoiceStatus {
  DRAFT
  PAID
  VOID
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ON_NOTICE
  EXITED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACTOR
  INTERN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

// ─── Tenant (Company) ─────────────────────────────────────────────────────────

model Tenant {
  id                String       @id @default(cuid())
  name              String
  slug              String       @unique
  domain            String?      @unique
  logoUrl           String?
  plan              Plan         @default(STARTER)
  planEmployeeLimit Int          @default(25)
  status            TenantStatus @default(ACTIVE)

  // India GST details
  gstin             String?
  address           String?
  city              String?
  state             String?
  pincode           String?
  supplyType        SupplyType   @default(INTRA_STATE)

  // Stripe
  stripeCustomerId  String?      @unique

  // Onboarding
  onboardingStatus  OnboardingStatus @default(PENDING)
  onboardingStep    Int              @default(1)

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  users             User[]
  employees         Employee[]
  subscriptions     Subscription[]
  invoices          Invoice[]
  departments       Department[]
  designations      Designation[]
  locations         Location[]
  roles             Role[]
  permissions       TenantPermission[]
  announcements     Announcement[]
  leaveTypes        LeaveType[]
  holidays          Holiday[]
  payrollRuns       PayrollRun[]

  @@map("tenants")
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  tenantId      String?
  email         String
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  isSuperAdmin  Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee      Employee? @relation("UserEmployee")
  userRoles     UserRole[]
  sessions      Session[]
  accounts      Account[]

  @@unique([tenantId, email])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── RBAC ─────────────────────────────────────────────────────────────────────

model Role {
  id          String       @id @default(cuid())
  tenantId    String?
  name        String
  description String?
  isSystem    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant      Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles   UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id              String           @id @default(cuid())
  resource        String
  action          String
  description     String?

  rolePermissions RolePermission[]
  tenantPermissions TenantPermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model TenantPermission {
  tenantId     String
  permissionId String

  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([tenantId, permissionId])
  @@map("tenant_permissions")
}

// ─── Organization Structure ───────────────────────────────────────────────────

model Department {
  id        String       @id @default(cuid())
  tenantId  String
  name      String
  code      String?
  parentId  String?
  headId    String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentHierarchy")
  employees Employee[]

  @@unique([tenantId, name])
  @@map("departments")
}

model Designation {
  id        String     @id @default(cuid())
  tenantId  String
  name      String
  level     Int?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@unique([tenantId, name])
  @@map("designations")
}

model Location {
  id        String     @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  city      String?
  state     String?
  pincode   String?
  isRemote  Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@unique([tenantId, name])
  @@map("locations")
}

// ─── Employees ────────────────────────────────────────────────────────────────

model Employee {
  id               String         @id @default(cuid())
  tenantId         String
  employeeCode     String
  userId           String?        @unique

  // Personal details
  firstName        String
  lastName         String
  email            String
  phone            String?
  dateOfBirth      DateTime?
  gender           Gender?
  bloodGroup       String?
  nationality      String?        @default("Indian")

  // Address
  address          String?
  city             String?
  state            String?
  pincode          String?

  // Emergency contact
  emergencyName    String?
  emergencyPhone   String?
  emergencyRelation String?

  // Job details
  departmentId     String?
  designationId    String?
  locationId       String?
  reportingTo      String?
  employmentType   EmploymentType @default(FULL_TIME)
  joiningDate      DateTime
  probationEndDate DateTime?
  confirmationDate DateTime?
  noticePeriodDays Int            @default(30)

  // Government IDs (stored encrypted in production)
  panNumber        String?
  aadhaarNumber    String?
  pfNumber         String?
  esicNumber       String?
  uanNumber        String?

  // Bank details
  bankName         String?
  bankAccountNumber String?
  bankIfscCode     String?
  bankAccountHolderName String?

  // Status
  status           EmployeeStatus @default(ACTIVE)
  exitDate         DateTime?
  exitReason       String?

  profilePhotoUrl  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User?          @relation("UserEmployee", fields: [userId], references: [id])
  department       Department?    @relation(fields: [departmentId], references: [id])
  designation      Designation?   @relation(fields: [designationId], references: [id])
  location         Location?      @relation(fields: [locationId], references: [id])
  reportingManager Employee?      @relation("ReportingHierarchy", fields: [reportingTo], references: [id])
  directReports    Employee[]     @relation("ReportingHierarchy")
  documents             EmployeeDocument[]
  salaryStructure       SalaryStructure?
  leaveBalances         LeaveBalance[]
  leaveRequests         LeaveRequest[]     @relation("LeaveApplicant")
  reviewedLeaves        LeaveRequest[]     @relation("LeaveReviewer")
  attendanceRecords     AttendanceRecord[]
  payrollEntries        PayrollEntry[]

  @@unique([tenantId, email])
  @@unique([tenantId, employeeCode])
  @@map("employees")
}

model EmployeeDocument {
  id          String   @id @default(cuid())
  employeeId  String
  name        String
  type        String
  url         String
  size        Int?
  uploadedAt  DateTime @default(now())

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_documents")
}

// ─── Leave Management ─────────────────────────────────────────────────────────

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveCategory {
  CASUAL
  SICK
  PRIVILEGE
  MATERNITY
  PATERNITY
  COMPENSATORY
  UNPAID
  OTHER
}

model LeaveType {
  id               String        @id @default(cuid())
  tenantId         String
  name             String
  code             String        // e.g., CL, SL, PL
  category         LeaveCategory
  daysAllowed      Int
  isCarryForward   Boolean       @default(false)
  maxCarryForward  Int           @default(0)
  isPaidLeave      Boolean       @default(true)
  requiresApproval Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaveRequests    LeaveRequest[]
  leaveBalances    LeaveBalance[]

  @@unique([tenantId, code])
  @@map("leave_types")
}

model LeaveBalance {
  id             String    @id @default(cuid())
  tenantId       String
  employeeId     String
  leaveTypeId    String
  year           Int
  allocated      Float
  used           Float     @default(0)
  pending        Float     @default(0)
  carriedForward Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  employee       Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType      LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveTypeId, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id            String      @id @default(cuid())
  tenantId      String
  employeeId    String
  leaveTypeId   String
  startDate     DateTime    @db.Date
  endDate       DateTime    @db.Date
  days          Float
  reason        String?
  status        LeaveStatus @default(PENDING)
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewComment String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  employee      Employee    @relation("LeaveApplicant", fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType     LeaveType   @relation(fields: [leaveTypeId], references: [id])
  reviewer      Employee?   @relation("LeaveReviewer", fields: [reviewedBy], references: [id])

  @@map("leave_requests")
}

// ─── Holidays ─────────────────────────────────────────────────────────────────

model Holiday {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  date      DateTime @db.Date
  isOptional Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@map("holidays")
}

// ─── Attendance ───────────────────────────────────────────────────────────────

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  ON_LEAVE
  HOLIDAY
  WEEKEND
  LATE
  WORK_FROM_HOME
}

model AttendanceRecord {
  id          String           @id @default(cuid())
  tenantId    String
  employeeId  String
  date        DateTime         @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  status      AttendanceStatus @default(PRESENT)
  hoursWorked Float?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@map("attendance_records")
}

// ─── Payroll ──────────────────────────────────────────────────────────────────

enum PayrollStatus {
  DRAFT
  PROCESSING
  COMPLETED
  CANCELLED
}

model PayrollRun {
  id          String        @id @default(cuid())
  tenantId    String
  month       Int
  year        Int
  status      PayrollStatus @default(DRAFT)
  processedAt DateTime?
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entries     PayrollEntry[]

  @@unique([tenantId, month, year])
  @@map("payroll_runs")
}

model PayrollEntry {
  id              String     @id @default(cuid())
  payrollRunId    String
  tenantId        String
  employeeId      String
  basic           Int
  hra             Int
  specialAllowance Int
  otherEarnings   Int        @default(0)
  grossEarnings   Int
  pf              Int
  esic            Int
  tds             Int
  otherDeductions Int        @default(0)
  totalDeductions Int
  netPay          Int
  workingDays     Int
  paidDays        Float
  lopDays         Float      @default(0)
  payslipUrl      String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  payrollRun      PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee        Employee   @relation(fields: [employeeId], references: [id])

  @@unique([payrollRunId, employeeId])
  @@map("payroll_entries")
}

// ─── Salary Structure ─────────────────────────────────────────────────────────

model SalaryStructure {
  id              String   @id @default(cuid())
  employeeId      String   @unique
  ctc             Int      // annual CTC in paise
  basic           Int
  hra             Int
  specialAllowance Int
  pf              Int
  esic            Int
  tds             Int
  effectiveFrom   DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("salary_structures")
}

// ─── Billing ──────────────────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String
  plan                 Plan
  planEmployeeLimit    Int
  billingCycleStart    DateTime
  billingCycleEnd      DateTime
  status               SubscriptionStatus @default(TRIALING)
  stripeSubscriptionId String?            @unique
  amount               Int                // in paise (GST incl.)
  trialEndsAt          DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  extraSlots           SubscriptionExtraSlot[]

  @@map("subscriptions")
}

model SubscriptionExtraSlot {
  id                    String       @id @default(cuid())
  subscriptionId        String
  tenantId              String
  slotsPurchased        Int
  billingCycleStart     DateTime
  billingCycleEnd       DateTime
  amountPaid            Int          // in paise (GST incl.)
  stripePaymentIntentId String?
  createdAt             DateTime     @default(now())

  subscription          Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("subscription_extra_slots")
}

model Invoice {
  id            String        @id @default(cuid())
  tenantId      String
  invoiceNumber String        @unique
  lineItems     Json
  taxableValue  Int           // in paise
  cgst          Int           // in paise
  sgst          Int           // in paise
  igst          Int           // in paise
  total         Int           // in paise (GST incl.)
  customerGstin String?
  supplyType    SupplyType    @default(INTRA_STATE)
  status        InvoiceStatus @default(PAID)
  pdfUrl        String?
  issuedAt      DateTime      @default(now())
  paidAt        DateTime?

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

// ─── Announcements ────────────────────────────────────────────────────────────

model Announcement {
  id        String   @id @default(cuid())
  tenantId  String
  title     String
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("announcements")
}
